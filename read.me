## 환경 설정

`monitor.js` 상단의 CONFIG 값을 실제 환경에 맞게 수정합니다.

```javascript
// WinCMS 설정
const CONFIG = {
  loginUrl: 'https://svc.wooribank.com/wsm/common/login_counsel.jsp',
  boardUrl: 'https://svc.wooribank.com/wsm/calladm/sysadmin/wccom500_01i.jsp',
  id: 'YOUR_ID',        // WinCMS 아이디
  pw: 'YOUR_PASSWORD',  // WinCMS 비밀번호
  birth: 'YYMMDD',      // 생년월일 6자리
};

// 다우메신저 설정
const DAOU_CONFIG = {
  loginUrl: 'https://kwic.daouoffice.com/api/portal/public/auth/login',
  messageUrl: 'https://kwic.daouoffice.com/api/chat/message',
  chatRoomId: 'YOUR_CHAT_ROOM_ID',  // 알림 받을 채팅방 ID
  id: 'YOUR_DAOU_ID',               // 다우메신저 아이디
  pw: 'YOUR_DAOU_PASSWORD',         // 다우메신저 비밀번호
};
```

